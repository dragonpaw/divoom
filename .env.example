# Copy to `.env` and fill in. `.env` is gitignored.
# Variables are consumed by docker-compose.yml at `up` time.

# Timezone for the daemon (affects scene rendering / clock).
TZ=America/Los_Angeles

# --- Frame targeting ---------------------------------------------------------
# MAC of the Times Frame to discover via Divoom's ReturnSameLANDevice endpoint.
# Leave empty to take the first device the cloud reports.
DIVOOM_FRAME_MAC=

# IP of the Times Frame on the LAN. Setting this skips cloud discovery, which
# is useful if you've firewalled the frame off the public internet.
DIVOOM_FRAME_IP=

# adb serial when more than one device is attached. Usually unset.
ADB_SERIAL=

# --- Widget API keys ---------------------------------------------------------
# NASA APOD (https://api.nasa.gov/). Free; DEMO_KEY works at low cadence.
NASA_API_KEY=

# GitHub activity scene. Both must be set or the scene is skipped.
# Token only needs `public_repo` read scope.
GITHUB_USER=
GITHUB_TOKEN=
