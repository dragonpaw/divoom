# Copy to `.env` and fill in. `.env` is gitignored.
# Variables are consumed by docker-compose.yml at `up` time.

# Timezone for the daemon (affects scene rendering / clock).
TZ=America/Los_Angeles

# --- Frame targeting ---------------------------------------------------------
# MAC of the Times Frame to discover via Divoom's ReturnSameLANDevice endpoint.
# Leave empty to take the first device the cloud reports.
DIVOOM_FRAME_MAC=

# IP of the Times Frame on the LAN. Setting this skips cloud discovery, which
# is useful if you've firewalled the frame off the public internet.
DIVOOM_FRAME_IP=

# (ADB_SERIAL is consumed only by the `push` subcommand on the dev box,
# never by the NAS-side `serve` container — set it in your shell env there
# if you have multiple Android devices attached, not in this file.)

# --- Widget API keys ---------------------------------------------------------
# NASA APOD (https://api.nasa.gov/). Free; DEMO_KEY works at low cadence.
NASA_API_KEY=

# GitHub activity scene. Both must be set or the scene is skipped.
# Token only needs `public_repo` read scope.
GITHUB_USER=
GITHUB_TOKEN=

# Wordnik Word-of-the-Day. Optional; widget falls back to a baked-in
# day-of-year wordlist if unset. Free tier at https://developer.wordnik.com/.
WORDNIK_API_KEY=

# Special dates (birthdays, anniversaries) rendered in red on the
# dayofyear calendar grid with a single-letter mark. Format:
# MM-DD:LETTER comma-separated. Unset/empty = no special dates.
# Example: DIVOOM_SPECIAL_DATES=01-13:A,03-22:B,12-25:C
DIVOOM_SPECIAL_DATES=

# Markets ticker rotation. Comma-separated symbols (Yahoo Finance
# format — supports stocks, ETFs, indices, crypto e.g. BTC-USD).
# Unset/empty defaults to QQQ. One ticker shown per scene activation,
# round-robin order.
DIVOOM_TICKERS=

# Reddit "top of day" scene. Comma-separated subreddit names; the
# "r/" prefix is optional and stripped automatically. Unset/empty
# drops the scene from the rotation entirely. One sub picked at
# random per activation; cached one hour to stay friendly to reddit's
# anonymous-IP rate limit. NSFW posts are NOT filtered.
# Example: DIVOOM_SUBREDDITS=pcgaming,3Dprinting,linux_gaming,SteamDeck
DIVOOM_SUBREDDITS=

# --- Rotation priority ----------------------------------------------------
# Comma-separated scene names whose weight gets multiplied by 4 in the
# weighted-random rotation. Layered ON TOP of each scene's base tier:
# informational scenes (weather/forecast/iss/etc.) have base weight 40,
# interesting scenes (quotes/cocktail/nasa/etc.) have base weight 20, and
# the env-listed user-priority scenes get those bases multiplied by 4
# (so a priority informational scene fires 160:20 vs default-interesting,
# 8× as often). Unknown names are logged and ignored. Unset/empty applies
# no priority bumps — the tier weights are the baseline.
DIVOOM_PRIORITY_SCENES=

# --- Deploy ------------------------------------------------------------------
# Portainer hub (on the NAS) — `make deploy` uses PORTAINER_TOKEN to create /
# update the divoom stack via the Portainer API.
#
# The deploy TARGET host (which Docker endpoint the stack lands on) is pinned
# in the Makefile as PORTAINER_ENDPOINT := 5 (plugger's agent endpoint, where
# the Times Frame is USB-attached). It is deliberately NOT taken from the
# environment, because $PORTAINER_ENDPOINT is exported globally as 3 (the
# NAS-local endpoint) for other tooling. Override per-invocation on the CLI if
# needed: `make PORTAINER_ENDPOINT=3 deploy`. List endpoints with `make stacks`
# (the EndpointId column).
#
# PORTAINER_TOKEN is an API key created under Portainer's user settings
# → Access tokens. Needs stack-update + container-log read scopes for
# `make deploy` and the log-fetching helpers respectively. May also be
# read from ~/.config/divoom/portainer-key if you prefer to keep it out
# of .env entirely. `make deploy` strips PORTAINER_* from the pushed stack
# env, so the token never lands in the container's runtime environment.
PORTAINER_TOKEN=
